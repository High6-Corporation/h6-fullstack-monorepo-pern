{
  "name": "high6-suite",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,magenta \"pnpm --filter @workspace/api-server dev\" \"pnpm --filter @workspace/web dev\"",
    "build": "pnpm --filter @workspace/api-server build && pnpm --filter @workspace/web build",
    "start": "pnpm --filter @workspace/api-server start",
    "typecheck": "pnpm -r run typecheck",
    "check:no-ts-nocheck": "bash scripts/check-no-ts-nocheck.sh",
    "check": "pnpm run check:no-ts-nocheck && pnpm run typecheck && pnpm run build",
    "codegen": "pnpm --filter @workspace/api-spec run codegen",
    "db:generate": "pnpm --filter @workspace/db run generate",
    "db:migrate": "pnpm --filter @workspace/db run migrate",
    "db:push": "pnpm --filter @workspace/db run push",
    "db:seed": "pnpm --filter @workspace/db run seed",
    "db:studio": "pnpm --filter @workspace/db run studio"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.3",
    "dotenv": "^17.4.2",
    "ulid": "^3.0.2"
  }
}
