# High6 Suite — Environment Configuration
# Copy this file to `.env` for local development. On Replit, set the same
# values via the Secrets pane.

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://root:password@localhost:5432/high6

# -----------------------------------------------------------------------------
# API server
# -----------------------------------------------------------------------------
PORT=3001
NODE_ENV=development

# Comma-separated list of allowed CORS origins for the API. Required in
# production when the web app is served from a different origin than the API.
# CORS_ORIGINS=https://app.example.com,https://www.example.com

# -----------------------------------------------------------------------------
# Web (Vite)
# -----------------------------------------------------------------------------
# Required. Vite's dev server proxies /api and /uploads to this target.
# Must match the PORT value above.
VITE_API_PROXY_TARGET=http://localhost:3001

# Leave unset to use the same-origin `/api` path in production.
# VITE_API_BASE_URL=/api

# -----------------------------------------------------------------------------
# Auth / SSO placeholder
# -----------------------------------------------------------------------------
# Local training only. Production blocks AUTH_BYPASS in the API middleware.
VITE_AUTH_BYPASS=true
AUTH_BYPASS=true
DEV_AUTH_USER_ID=dev-user
DEV_AUTH_TENANT_ID=dev-tenant

# Future High6 SSO / Clerk / identity provider placeholder.
# Do not trust tenant or role values from the frontend. Resolve them server-side.
# CLERK_SECRET_KEY=
# VITE_CLERK_PUBLISHABLE_KEY=
# SSO_ISSUER_URL=
# SSO_AUDIENCE=
# SSO_JWKS_URL=

# -----------------------------------------------------------------------------
# Uploads
# -----------------------------------------------------------------------------
# Local upload folder for the current starter. For Replit production, replace
# with Replit Object Storage or another approved object storage provider.
# UPLOAD_DIR=public/uploads